{
  "name": "ghostcommit-vscode",
  "displayName": "GhostCommit",
  "description": "GhostCommit VS Code Extension",
  "version": "0.0.1",
  "publisher": "sharma3008",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onCommand:ghostcommit.test"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ghostcommit.test",
        "title": "GhostCommit: Test"
      }
    ],
    "configuration": {
      "title": "GhostCommit",
      "properties": {
        "ghostcommit.apiBaseUrl": {
          "type": "string",
          "default": "http://localhost:8000",
          "description": "GhostCommit API base URL (e.g., http://localhost:8000)"
        },
        "ghostcommit.apiToken": {
          "type": "string",
          "default": "",
          "description": "GhostCommit API token (if enabled on the server)",
          "markdownDescription": "GhostCommit API token (if enabled on the server). Stored in settings; prefer using VS Code SecretStorage in later issues."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2",
    "esbuild": "^0.27.2",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}